FROM ubuntu:24.04@sha256:d1e2e92c075e5ca139d51a140fff46f84315c0fdce203eab2807c7e495eff4f9

ARG ZELLIJ_TAG
ARG ZELLIJ_SHA256

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       bash \
       ca-certificates \
       curl \
       git \
       jq \
       libatomic1 \
       util-linux \
    && curl -fsSL "https://github.com/dapi/zellij-main/releases/download/${ZELLIJ_TAG}/zellij" \
       -o /tmp/zellij \
    && echo "${ZELLIJ_SHA256}  /tmp/zellij" | sha256sum -c - \
    && install -m 755 /tmp/zellij /usr/local/bin/zellij \
    && rm -f /tmp/zellij \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /test
